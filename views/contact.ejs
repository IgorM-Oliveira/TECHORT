    <div class="site-section bg-light">
      <div class="container">
        <div class="row">
          <div class="col-md-7 mb-5">

            <form action="/send-email" method="post" role="form" class="p-5 bg-white">

              <div class="row form-group">
                <div class="col-md-6 mb-3 mb-md-0">
                  <label class="text-black" for="fname">Primeiro Nome</label>
                  <input type="text" name="pri" id="fname" class="form-control" placeholder="Coleque o primeiro nome">
                </div>
                <div class="col-md-6">
                  <label class="text-black" for="lname">Ultimo Nome</label>
                  <input type="text" name="sug" id="lname" class="form-control" placeholder="Coleque o ultimo nome">
                </div>
              </div>

              <div class="row form-group">
                <div class="col-md-12">
                  <label class="text-black" for="email">Gmail</label> 
                  <input type="email" name="from" id="email" class="form-control" placeholder="Insira seu Gmail">
                </div>
              </div>

              <div class="row form-group">
                <div class="col-md-12">
                  <label class="text-black" for="subject">Assunto</label> 
                  <input type="subject" name="subject" id="subject" class="form-control" placeholder="Insira assunto do email que sera enviado.">
                </div>
              </div>

              <div class="row form-group">
                <div class="col-md-12">
                  <label class="text-black" for="message">Mensagem</label> 
                  <textarea name="body" id="message" cols="30" rows="7" class="form-control" placeholder="Escreva suas anotações ou perguntas aqui ..."></textarea>
                </div>
              </div>

              <div class="row form-group">
                <div class="col-md-12">
                  <input type="submit" value="Enviar Mensagem" class="btn btn-primary py-2 px-4 text-white">
                </div>
              </div>

            </form>
            
